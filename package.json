{
  "name": "alghwairy_fin",
  "private": true,
  "version": "1.0.0",
  "description": "مؤسسة الغويري للتخليص الجمركي - المنظومة السيادية",
  "author": "Alghwairy Sovereign Finance",
  "main": "main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^1.7.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "build": {
    "appId": "com.algh.sovereign.ledger",
    "productName": "Alghwairy Customs Clearance",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "package.json",
      "assets/**/*",
      "ALGHWAIRY_SOVEREIGN_MANUAL.md"
    ],
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "مؤسسة الغويري للتخليص الجمركي",
      "artifactName": "Alghwairy-Customs-Clearance-Setup-${version}.${ext}"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "asar": true,
    "copyright": "Copyright © 2026 Alghwairy Customs Clearance Institution"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/html2pdf.js": "^0.10.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
